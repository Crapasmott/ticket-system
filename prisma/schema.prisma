generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tecnico {
  id        Int      @id @default(autoincrement())
  nombre    String
  usuario   String   @unique
  password  String   @default("123456")
  role      String   @default("tecnico")
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())

  tickets   Ticket[]

  @@map("tecnicos")
}

model Empleado {
  id          Int      @id @default(autoincrement())
  nombre      String
  cargo       String
  dependencia String
  equipo      String
  ip          String?
  tipo        String
  serial      String?
  monitor     String?
  macEthernet String?
  macWifi     String?
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now())

  tickets     Ticket[]

  @@map("empleados")
}

model Ticket {
  id            Int      @id @default(autoincrement())
  fecha         DateTime
  edificio      String
  tipoEquipo    String
  nombreEquipo  String?
  observaciones String?
  estado        String   @default("COMPLETADO")
  componentes   Json
  firmaTecnico  String?  @db.Text
  firmaUsuario  String?  @db.Text
  tecnicoId     Int
  tecnico       Tecnico  @relation(fields: [tecnicoId], references: [id])
  empleadoId    Int
  empleado      Empleado @relation(fields: [empleadoId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tecnicoId])
  @@index([empleadoId])
  @@index([fecha])
  @@map("tickets")
}